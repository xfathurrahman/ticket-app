{
	"name": "ticket-app",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.4.2",
			"zod": "^4.4.3",
			"typescript": "^6",
			"@types/bun": "^1.3.14",
			"@types/node": "^22.13.14",
			"hono": "^4.12.27",
			"@trpc/server": "^11.18.0",
			"lucide-react": "^1.23.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.7",
			"react-dom": "^19.2.7",
			"sonner": "^2.0.7",
			"@trpc/client": "^11.18.0",
			"@types/react": "^19.2.17",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.3.2"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"dev:web": "turbo run dev -F web",
		"dev:server": "turbo run dev -F server",
		"db:push": "turbo run db:push -F @ticket-app/db",
		"db:studio": "turbo run db:studio -F @ticket-app/db",
		"db:generate": "turbo run db:generate -F @ticket-app/db",
		"db:migrate": "turbo run db:migrate -F @ticket-app/db",
		"db:local": "turbo run db:local -F @ticket-app/db",
		"deploy:setup": "vercel link",
		"dev:vercel": "vercel dev -L",
		"env:preview": "tsx scripts/sync-vercel-env.ts preview",
		"env:production": "tsx scripts/sync-vercel-env.ts production",
		"deploy": "vercel deploy",
		"deploy:prod": "vercel deploy --prod",
		"deploy:check": "vercel deploy --dry",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@ticket-app/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@ticket-app/config": "workspace:*",
		"@types/bun": "catalog:",
		"@types/node": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"tsx": "^4.22.5",
		"turbo": "^2.10.2",
		"typescript": "catalog:",
		"vercel": "^54.18.6"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"packageManager": "bun@1.3.14"
}
