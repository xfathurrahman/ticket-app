{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@hono/trpc-server": "^0.4.2",
		"@hono/zod-openapi": "^1.5.1",
		"@scalar/hono-api-reference": "^0.11.11",
		"@ticket-app/api": "workspace:*",
		"@ticket-app/db": "workspace:*",
		"@ticket-app/env": "workspace:*",
		"@trpc/server": "catalog:",
		"dotenv": "catalog:",
		"hono": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@ticket-app/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "^0.22.3",
		"typescript": "catalog:"
	}
}
