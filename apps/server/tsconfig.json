{
	"extends": "@ticket-app/config/tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"outDir": "dist",
		"paths": {
			"@/*": ["./src/*"]
		},
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"rootDir": "."
	},
	"include": ["src", "tsdown.config.ts"],
	"exclude": ["node_modules", "dist", "server"]
}
